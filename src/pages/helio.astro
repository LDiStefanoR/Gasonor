---
import Layout from "../layouts/Layout.astro";
import { site, whatsappLink } from "../data/site";

const eventos = [
  { icon: "🎂", title: "Cumpleaños", text: "Sorprendé con globos que flotan horas. Ideal para fiestas en casa o salones." },
  { icon: "💒", title: "Bodas", text: "Arcos, centros de mesa y ambientación con helio de calidad para el día más especial." },
  { icon: "🎉", title: "Eventos especiales", text: "15 años, bautismos, aniversarios y celebraciones que piden un detalle memorable." },
  { icon: "✨", title: "Decoradoras", text: "Trabajamos con decoradoras y organizadores de eventos en Rosario y zona." },
  { icon: "🏢", title: "Empresas", text: "Inauguraciones, lanzamientos y activaciones que necesitan impacto visual." },
  { icon: "🎁", title: "El mejor regalo", text: "Un kit de helio es un regalo original, práctico y que alegra cualquier celebración." },
];
---

<Layout
  title="Helio para Globos y Eventos"
  description="Alquiler de helio para globos en Rosario. Hasta 120 globos por envase, eventos, bodas, cumpleaños y grandes inflados. Gasonor S.R.L."
  whatsappMessage="Hola Gasonor, consulto por helio para globos / evento."
>

  <!-- HERO -->
  <section class="relative overflow-hidden text-white min-h-[460px] flex items-center" style="background: linear-gradient(135deg, #006030 0%, #397f34 45%, #8fbc6e 100%);">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_85%_15%,rgba(255,255,255,0.18),transparent_50%)]"></div>
    <div class="absolute top-10 left-[10%] text-4xl opacity-20 animate-pulse" aria-hidden="true">🎈</div>
    <div class="absolute bottom-16 right-[15%] text-3xl opacity-15" aria-hidden="true">🎈</div>
    <div class="relative max-w-7xl mx-auto section-pad w-full">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <span class="inline-block px-3 py-1 rounded-full bg-white/20 text-gasonor-nav text-sm font-bold mb-4">
            Helio para globos · Rosario
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-5 !text-white">
            Que tu evento vuele en serio
          </h1>
          <p class="text-white/90 text-lg sm:text-xl leading-relaxed mb-6">
            Alquiler de helio para cumpleaños, bodas, fiestas y eventos especiales. Trabajamos con
            decoradoras, familias y empresas que buscan un resultado profesional sin complicaciones.
          </p>
          <p class="text-white/80 leading-relaxed mb-8">
            El helio es el mejor regalo que podés hacer: original, festivo y listo para inflar
            cientos de globos en minutos. Vendemos helio y globos — no realizamos trabajos de globología.
          </p>
          <a
            href={whatsappLink("Hola Gasonor, tengo un evento y necesito helio para globos.")}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary !bg-white !text-gasonor-primary hover:!bg-gasonor-nav"
          >
            Reservar helio por WhatsApp
          </a>
        </div>
        <img
          src="/assets/productos/helio.jpeg"
          alt="Helio para globos y eventos"
          class="rounded-3xl shadow-2xl w-full max-h-80 object-cover ring-4 ring-white/25"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- PARA QUIÉN -->
  <section class="section-pad bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">Para cada tipo de celebración</h2>
        <p class="text-body text-lg">
          Desde una fiesta íntima hasta un evento grande, tenemos la modalidad de helio que necesitás.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          eventos.map((item) => (
            <div class="p-6 sm:p-7 rounded-3xl bg-brand-50 border border-brand-200 card-hover text-center">
              <div class="text-4xl mb-3" aria-hidden="true">{item.icon}</div>
              <h3 class="text-lg font-extrabold text-gasonor-primary mb-2">{item.title}</h3>
              <p class="text-body text-sm leading-relaxed">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ALQUILER PRINCIPAL -->
  <section id="alquiler" class="section-pad bg-brand-50">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1 relative">
        <div class="absolute -top-4 -left-4 w-24 h-24 rounded-full bg-gasonor-nav/40 blur-2xl" aria-hidden="true"></div>
        <div class="relative p-8 sm:p-10 rounded-3xl bg-white border-2 border-gasonor-primary shadow-xl">
          <div class="text-center mb-6">
            <span class="text-5xl font-extrabold text-gasonor-primary">120</span>
            <p class="text-lg font-bold text-gasonor-ink mt-1">globos por envase</p>
          </div>
          <ul class="space-y-4 text-body">
            <li class="flex gap-3">
              <span class="text-gasonor-accent font-bold shrink-0">✓</span>
              Envase de helio <strong>liviano</strong> y fácil de transportar
            </li>
            <li class="flex gap-3">
              <span class="text-gasonor-accent font-bold shrink-0">✓</span>
              Capacidad para inflar hasta <strong>120 globos</strong>
            </li>
            <li class="flex gap-3">
              <span class="text-gasonor-accent font-bold shrink-0">✓</span>
              <strong>Depósito en garantía</strong> — lo recuperás al devolver el envase
            </li>
            <li class="flex gap-3">
              <span class="text-gasonor-accent font-bold shrink-0">✓</span>
              Solo abonás la <strong>carga del helio</strong>
            </li>
          </ul>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <span class="text-gasonor-accent text-sm font-bold uppercase tracking-wider">Modalidad más pedida</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mt-2 mb-5">Alquiler de helio</h2>
        <p class="text-body text-lg leading-relaxed mb-6">
          Te prestamos un envase de helio liviano con capacidad de inflar hasta 120 globos. A cambio
          te pedimos un depósito en garantía que recuperás cuando nos devolvés el envase en condiciones.
        </p>
        <p class="text-body leading-relaxed mb-8">
          Solo abonás la carga del helio. Simple, económico y perfecto para cumpleaños, decoración
          de salones y eventos donde querés hacer vos mismo la ambientación.
        </p>
        <a
          href={whatsappLink("Hola Gasonor, quiero alquilar helio para globos (hasta 120).")}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Consultar alquiler
        </a>
      </div>
    </div>
  </section>

  <!-- GRANDES CANTIDADES -->
  <section id="eventos-grandes" class="section-pad bg-gasonor-primary text-white">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block px-3 py-1 rounded-full bg-white/15 text-gasonor-nav text-sm font-bold mb-4">
          Pedidos especiales
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-5 !text-white">
          Grandes cantidades y inflados especiales
        </h2>
        <p class="text-white/90 text-lg leading-relaxed mb-6">
          Para alquileres especiales de grandes cantidades de helio, por encargo especial proveemos
          gas para inflados de <strong class="text-gasonor-nav">zepelines y globos de gran formato</strong>.
        </p>
        <p class="text-white/85 leading-relaxed mb-8">
          Eventos corporativos, activaciones, desfiles y producciones que requieren volumen superior
          al envase estándar. Coordinamos logística y cantidad según tu proyecto.
        </p>
        <div class="p-5 rounded-2xl bg-white/10 border border-white/20 mb-8">
          <p class="font-bold text-gasonor-nav mb-1">Condición de reserva</p>
          <p class="text-white/90 text-sm">
            Pedidos especiales de gran volumen: <strong>50% del pedido por adelantado</strong> para
            confirmar la provisión y reservar el gas.
          </p>
        </div>
        <a
          href={whatsappLink("Hola Gasonor, necesito helio en gran cantidad / inflado especial (zepelín o evento grande).")}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary !bg-gasonor-nav !text-gasonor-primary hover:!bg-white"
        >
          Cotizar evento grande
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {
          [
            { n: "120+", l: "Globos estándar", d: "Por envase liviano" },
            { n: "50%", l: "Anticipo", d: "Pedidos especiales" },
            { n: "🎈", l: "Gran formato", d: "Zepelines e inflados" },
            { n: "📅", l: "A medida", d: "Fecha y cantidad acordada" },
          ].map((stat) => (
            <div class="p-5 rounded-2xl bg-white/10 border border-white/15 text-center backdrop-blur-sm">
              <div class="text-2xl font-extrabold text-gasonor-nav mb-1">{stat.n}</div>
              <div class="font-bold text-sm mb-1">{stat.l}</div>
              <div class="text-xs text-white/70">{stat.d}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- OTRAS MODALIDADES -->
  <section class="section-pad bg-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-extrabold text-center mb-10">Otras formas de conseguir helio</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {
          [
            {
              t: "Recarga",
              d: "¿Ya tenés tu envase? Recargamos tubos de helio propios con la cantidad que necesites.",
              icon: "🔄",
            },
            {
              t: "Comodato",
              d: "Envases cargados listos para retirar, con la cantidad de gas acordada para tu evento.",
              icon: "📦",
            },
            {
              t: "Venta de globos",
              d: "Complementá tu pedido de helio con globos. Te asesoramos sobre cantidades y tamaños.",
              icon: "🛒",
            },
          ].map((m) => (
            <div class="p-8 rounded-3xl bg-gradient-to-b from-brand-50 to-white border border-brand-200 card-hover text-center">
              <div class="text-4xl mb-4" aria-hidden="true">{m.icon}</div>
              <h3 class="text-xl font-bold text-gasonor-ink mb-2">{m.t}</h3>
              <p class="text-body text-sm leading-relaxed">{m.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CÓMO FUNCIONA -->
  <section class="section-pad bg-brand-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-extrabold text-center mb-10">¿Cómo reservar?</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        {
          [
            { step: "1", title: "Escribinos", text: "WhatsApp con fecha, tipo de evento y cantidad aproximada de globos." },
            { step: "2", title: "Retirá o coordiná", text: "Te indicamos envase, depósito y costo de la carga de helio." },
            { step: "3", title: "¡A celebrar!", text: "Inflá, decorá y devolvé el envase para recuperar tu garantía." },
          ].map((item) => (
            <div class="text-center p-6">
              <div class="w-12 h-12 rounded-full bg-gasonor-primary text-white font-extrabold text-xl flex items-center justify-center mx-auto mb-4">
                {item.step}
              </div>
              <h3 class="font-extrabold text-gasonor-primary mb-2">{item.title}</h3>
              <p class="text-body text-sm">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad bg-white">
    <div class="max-w-3xl mx-auto text-center rounded-3xl bg-gradient-to-br from-gasonor-nav via-brand-100 to-white p-10 sm:p-14 border border-brand-200 shadow-lg">
      <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">¿Tenés un evento próximo?</h2>
      <p class="text-body text-lg mb-2">
        Cumpleaños, boda, fiesta o producción con decoradoras — contanos la fecha y te asesoramos.
      </p>
      <p class="text-gasonor-accent font-bold mb-8">
        {site.coverage} · Respuesta rápida por WhatsApp
      </p>
      <a
        href={whatsappLink("Hola Gasonor, tengo un evento y necesito helio para globos.")}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-[#25D366] text-white font-bold hover:scale-105 transition-all shadow-xl shadow-[#25D366]/30"
      >
        Consultar por WhatsApp — {site.whatsappDisplay}
      </a>
    </div>
  </section>

</Layout>
