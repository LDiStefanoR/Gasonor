---
import type { LogoItem } from "../data/partners";

interface Props {
  title: string;
  description: string;
  items: LogoItem[];
  variant?: "partners" | "clients";
}

const { title, description, items, variant = "partners" } = Astro.props;
const isClients = variant === "clients";
---

<section class:list={["section-pad", isClients ? "bg-white" : "bg-brand-50 border-y border-brand-200"]}>
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class:list={[
        "inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-4",
        isClients ? "bg-gasonor-primary text-white" : "bg-gasonor-nav text-gasonor-primary",
      ]}>
        {isClients ? "Confían en nosotros" : "Alianzas"}
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">{title}</h2>
      <p class="text-body text-lg">{description}</p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      {
        items.map((item) => {
          const inner = (
            <div class="group flex flex-col items-center justify-center h-full p-5 sm:p-6 rounded-2xl bg-white border border-brand-200 shadow-sm hover:shadow-lg hover:border-gasonor-accent/40 transition-all card-hover min-h-[140px]">
              <div class="flex items-center justify-center w-full h-16 sm:h-20 mb-3 px-2">
                <img
                  src={item.image}
                  alt={item.name}
                  class="max-h-full max-w-full w-auto object-contain grayscale group-hover:grayscale-0 transition-all duration-300"
                  loading="lazy"
                />
              </div>
              <p class="text-sm font-bold text-gasonor-primary text-center leading-tight">{item.name}</p>
              {item.subtitle && (
                <p class="text-xs text-gasonor-accent text-center mt-1">{item.subtitle}</p>
              )}
            </div>
          );

          return item.href ? (
            <a href={item.href} target="_blank" rel="noopener noreferrer" class="block h-full" title={item.name}>
              {inner}
            </a>
          ) : (
            <div class="h-full">{inner}</div>
          );
        })
      }
    </div>
  </div>
</section>
